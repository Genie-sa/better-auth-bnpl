{
	"name": "better-auth-bnpl",
	"version": "0.2.5",
	"description": "Buy-Now-Pay-Later plugin for Better Auth — unified checkout, orders, webhooks, and admin across Tabby and Tamara. Pluggable providers, end-user picker, fully type-safe.",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		},
		"./client": {
			"import": {
				"types": "./dist/client.d.ts",
				"default": "./dist/client.js"
			},
			"require": {
				"types": "./dist/client.d.cts",
				"default": "./dist/client.cjs"
			}
		},
		"./server-client": {
			"import": {
				"types": "./dist/server-client.d.ts",
				"default": "./dist/server-client.js"
			},
			"require": {
				"types": "./dist/server-client.d.cts",
				"default": "./dist/server-client.cjs"
			}
		},
		"./tamara": {
			"import": {
				"types": "./dist/providers/tamara/index.d.ts",
				"default": "./dist/providers/tamara/index.js"
			},
			"require": {
				"types": "./dist/providers/tamara/index.d.cts",
				"default": "./dist/providers/tamara/index.cjs"
			}
		},
		"./tabby": {
			"import": {
				"types": "./dist/providers/tabby/index.d.ts",
				"default": "./dist/providers/tabby/index.js"
			},
			"require": {
				"types": "./dist/providers/tabby/index.d.cts",
				"default": "./dist/providers/tabby/index.cjs"
			}
		}
	},
	"type": "module",
	"sideEffects": false,
	"packageManager": "pnpm@10.13.1",
	"engines": {
		"node": ">=18"
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"lint": "biome check ./src",
		"lint:fix": "biome check --write ./src",
		"check": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
		"format": "biome format --write ./src",
		"openapi:sync": "node scripts/sync-openapi-specs.mjs",
		"openapi:generate": "openapi-typescript openapi/tabby.openapi.yaml -o src/providers/tabby/openapi.ts && openapi-typescript openapi/tamara.openapi.json -o src/providers/tamara/openapi.ts && node scripts/strip-ts-comments.mjs src/providers/tabby/openapi.ts src/providers/tamara/openapi.ts && biome format --write src/providers/tabby/openapi.ts src/providers/tamara/openapi.ts",
		"openapi:check": "pnpm openapi:generate && git diff --exit-code -- openapi src/providers/tabby/openapi.ts src/providers/tamara/openapi.ts",
		"changeset": "changeset",
		"version-packages": "changeset version",
		"release": "pnpm build && changeset publish",
		"prepare": "pnpm build",
		"prepublishOnly": "pnpm typecheck && pnpm lint && pnpm test && pnpm build"
	},
	"files": [
		"dist",
		"skills",
		"README.md",
		"LICENSE"
	],
	"keywords": [
		"better-auth",
		"better-auth-plugin",
		"bnpl",
		"buy-now-pay-later",
		"tabby",
		"tamara",
		"payments",
		"checkout",
		"webhooks",
		"saudi-arabia",
		"uae",
		"kuwait",
		"mena",
		"gcc"
	],
	"homepage": "https://github.com/Genie-sa/better-auth-bnpl#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Genie-sa/better-auth-bnpl.git"
	},
	"bugs": {
		"url": "https://github.com/Genie-sa/better-auth-bnpl/issues"
	},
	"author": "Ali Dhamen",
	"license": "MIT",
	"peerDependencies": {
		"better-auth": "^1.5.0",
		"zod": "^3.24.0 || ^4"
	},
	"devDependencies": {
		"@changesets/cli": "^2.31.0",
		"@biomejs/biome": "^1.9.4",
		"@types/node": "^20.0.0",
		"@vitest/coverage-v8": "^2.1.9",
		"better-auth": "^1.4.18",
		"openapi-typescript": "^7.13.0",
		"pkg-pr-new": "^0.0.75",
		"tsup": "^8.5.1",
		"typescript": "^5.6.0",
		"vitest": "^2.1.8",
		"zod": "^3.24.2"
	}
}
